{
	"name": "obsidian-wechat-converter",
	"version": "2.8.8",
	"description": "Apple Style Formatter for Obsidian",
	"main": "main.js",
	"scripts": {
		"generate:embedded": "node scripts/generate-embedded-deps.mjs",
		"check:embedded": "node scripts/generate-embedded-deps.mjs --check",
		"generate:ai-layout-runtime": "node scripts/build-ai-layout-runtime.mjs",
		"check:ai-layout-runtime": "node scripts/build-ai-layout-runtime.mjs --check",
		"generate:runtime": "npm run generate:embedded && npm run generate:ai-layout-runtime",
		"check:runtime": "npm run check:embedded && npm run check:ai-layout-runtime",
		"dev": "npm run generate:runtime && node esbuild.config.mjs",
		"build": "npm run generate:runtime && node esbuild.config.mjs production",
		"pretest": "npm run check:runtime",
		"test": "vitest",
		"test:coverage": "vitest run --coverage",
		"measure:latency": "node scripts/measure-native-latency.mjs",
		"measure:latency:stability": "node scripts/measure-native-latency.mjs --rounds 5",
		"release:pack": "bash package-release.sh",
		"release:validate": "node scripts/release-validate.mjs",
		"release:dryrun": "npm run build && npm run release:pack && npm run release:validate",
		"lint": "eslint .",
		"deploy:server": "rsync -avz --exclude 'node_modules' --exclude 'database.db' --exclude '*.log' ./server/ tencent:~/wechat-proxy/ && ssh tencent 'cd ~/wechat-proxy && npm install --production && /root/.nvm/versions/node/v22.22.0/bin/pm2 restart wechat-proxy || /root/.nvm/versions/node/v22.22.0/bin/pm2 start app.js --name wechat-proxy'"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"apple",
		"style",
		"formatter"
	],
	"author": "DavidLam (林小卫很行)",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/utils": "^8.61.1",
		"@vitest/coverage-v8": "^4.0.18",
		"esbuild": "0.17.3",
		"eslint": "^9.0.0",
		"eslint-plugin-obsidian": "^2.32.0",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^15.0.0",
		"highlight.js": "^11.11.1",
		"jsdom": "^28.0.0",
		"markdown-it": "^14.2.0",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4",
		"vitest": "^4.0.18",
		"ws": "^8.20.0"
	},
	"dependencies": {
		"markdown-it-mathjax3": "^4.3.2"
	},
	"overrides": {
		"@xmldom/xmldom": "0.9.10"
	}
}
