{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "input.js",
    "services/**/*.js",
    "views/**/*.js",
    "tests/**/*.js",
    "scripts/**/*.mjs",
    "esbuild.config.mjs",
    "rednote/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "coverage",
    "main.js",
    "lib/**/*.js"
  ]
}
